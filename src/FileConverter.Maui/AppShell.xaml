<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FileConverter.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:FileConverter.Maui.Pages"
    Title="FileConverter">

    <TabBar>
        <ShellContent Title="Convert" Icon="dotnet_bot.png"
                      ContentTemplate="{DataTemplate pages:ConvertPage}" />
        <ShellContent Title="History"
                      ContentTemplate="{DataTemplate pages:HistoryPage}" />
        <ShellContent Title="Settings"
                      ContentTemplate="{DataTemplate pages:SettingsPage}" />
    </TabBar>

</Shell>
