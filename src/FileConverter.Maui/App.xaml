<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FileConverter.Maui"
             xmlns:converters="clr-namespace:FileConverter.Maui.Converters"
             x:Class="FileConverter.Maui.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:IntToBoolConverter x:Key="IntToBoolConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:StringToBoolConverter x:Key="StringToBoolConverter" />
            <converters:CompletedConverter x:Key="CompletedConverter" />
            <converters:ConvertButtonTextConverter x:Key="ConvertButtonTextConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
