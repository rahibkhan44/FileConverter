<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FileConverter.Maui.Pages.HistoryPage"
             Title="History">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Conversion History"
               FontSize="24" FontAttributes="Bold" />
        <Label Text="Your recent conversions from this session will appear here."
               TextColor="Gray" FontSize="14" />
        <Label Text="Files are auto-deleted from the server after 1 hour."
               TextColor="Gray" FontSize="12" />
    </VerticalStackLayout>
</ContentPage>
