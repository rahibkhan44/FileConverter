<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FileConverter.Maui.Pages.SettingsPage"
             Title="Settings">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Settings" FontSize="24" FontAttributes="Bold" />

        <Label Text="API Server URL" FontSize="14" FontAttributes="Bold" />
        <Entry x:Name="ApiUrlEntry" Placeholder="https://localhost:7001" />
        <Button Text="Save" Clicked="OnSaveClicked" HorizontalOptions="Start" />

        <BoxView HeightRequest="1" Color="LightGray" Margin="0,10" />

        <Label Text="About" FontSize="18" FontAttributes="Bold" />
        <Label Text="FileConverter v1.0" FontSize="14" />
        <Label Text="Free file conversion for documents and images." FontSize="14" TextColor="Gray" />
        <Label Text="Supports: PDF, DOCX, XLSX, CSV, PPTX, TXT, RTF, PNG, JPG, WebP, GIF, BMP, TIFF, SVG"
               FontSize="12" TextColor="Gray" />
    </VerticalStackLayout>
</ContentPage>
