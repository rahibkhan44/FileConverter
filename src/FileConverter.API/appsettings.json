{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=fileconverter.db"
  },
  "Jwt": {
    "Key": "FileConverterDefaultSecretKey2024!@#$%^&*()MinLength32",
    "Issuer": "FileConverter",
    "Audience": "FileConverter"
  },
  "FileConverter": {
    "MaxFileSizeBytes": 524288000,
    "MaxBatchFiles": 100,
    "MaxBatchTotalBytes": 2147483648,
    "JobExpiryHours": 2,
    "RateLimit": {
      "DailyConversionsPerIp": 50,
      "RequestsPerMinute": 30
    }
  }
}
