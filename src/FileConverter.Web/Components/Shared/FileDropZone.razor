@inject IJSRuntime JS

<div class="drop-zone @(_isDragOver ? "drag-over" : "")"
     @ondragenter="OnDragEnter"
     @ondragover="OnDragOver"
     @ondragleave="OnDragLeave"
     @ondrop="OnDrop">

    <InputFile OnChange="OnFileSelected" multiple class="drop-zone-input" id="fileInput" />

    <div class="drop-zone-content">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16" class="text-primary mb-3">
            <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/>
            <path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708z"/>
        </svg>
        <h5>Drop files here or click to browse</h5>
        <p class="text-muted mb-0">Up to 100 files, max 50MB each</p>
    </div>
</div>

@code {
    [Parameter] public EventCallback<InputFileChangeEventArgs> OnFilesSelected { get; set; }

    private bool _isDragOver;

    private void OnDragEnter() => _isDragOver = true;
    private void OnDragOver() { }
    private void OnDragLeave() => _isDragOver = false;
    private void OnDrop() => _isDragOver = false;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _isDragOver = false;
        await OnFilesSelected.InvokeAsync(e);
    }
}
