@page "/about"

<PageTitle>About - FileConverter</PageTitle>

<div class="container py-5">
    <h1 class="mb-4">About FileConverter</h1>

    <div class="row">
        <div class="col-md-6">
            <h4>Image Conversions</h4>
            <p>Convert between PNG, JPG, WebP, GIF, BMP, TIFF (any-to-any) and SVG to raster formats.</p>

            <h4 class="mt-4">Document Conversions</h4>
            <ul>
                <li><strong>DOCX</strong> to PDF, TXT</li>
                <li><strong>DOC</strong> to PDF, DOCX, TXT</li>
                <li><strong>XLSX/XLS</strong> to PDF, CSV</li>
                <li><strong>CSV</strong> to PDF, XLSX</li>
                <li><strong>PPTX</strong> to PDF, TXT</li>
                <li><strong>PPT</strong> to PDF, PPTX</li>
                <li><strong>TXT</strong> to PDF</li>
                <li><strong>RTF</strong> to PDF, TXT, DOCX</li>
                <li><strong>PDF</strong> to TXT</li>
            </ul>
        </div>

        <div class="col-md-6">
            <h4>Features</h4>
            <ul>
                <li>No login required</li>
                <li>Batch upload up to 100 files</li>
                <li>Drag-and-drop upload</li>
                <li>Per-file progress tracking</li>
                <li>Download individually or as ZIP</li>
                <li>Advanced options (quality, DPI, page size, etc.)</li>
                <li>Files auto-deleted after 1 hour</li>
            </ul>

            <h4 class="mt-4">Limits</h4>
            <ul>
                <li>20 conversions per day (free)</li>
                <li>50MB max per file</li>
                <li>100 files max per batch</li>
            </ul>
        </div>
    </div>
</div>
